<?xml version="1.0" encoding="UTF-8"?>
<!-- Persistence deployment descriptor for dev profile -->
<persistence xmlns="http://java.sun.com/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_1_0.xsd" version="1.0">
	<persistence-unit name="pdks" transaction-type="JTA">
		<provider>org.hibernate.ejb.HibernatePersistence</provider>
		<jta-data-source>jdbc/pdks</jta-data-source>
		<properties>
			<!-- CANLI <property name="hibernate.hbm2ddl.auto" value="update"/> 
						<property name="javax.persistence.query.timeout" value="30" />
				<property name="hibernate.c3p0.timeout" value="30" />
			Dev -->
			<property name="hibernate.format_sql" value="false" />
			<property name="hibernate.max_fetch_depth" value="2" />
			<property name="hibernate.default_batch_fetch_size" value="32" />
			<property name="hibernate.jdbc.batch_size" value="25" />
			<property name="hibernate.jdbc.fetch_size" value="8" />
 			<property name="hibernate.transaction.timeout" value="30" />
			<property name="hibernate.connection.characterEncoding" value="UTF-8" />
			<!-- glassfish -->
			<property name="hibernate.dialect" value="org.hibernate.dialect.SQLServerDialect" />
			<property name="hibernate.transaction.manager_lookup_class" value="org.hibernate.transaction.SunONETransactionManagerLookup" />
			<property name="javax.persistence.query.timeout" value="60000" />
			<property name="hibernate.c3p0.timeout" value="450" />
			<property name="hibernate.c3p0.preferredTestQuery" value="SELECT 1" />
			<property name="hibernate.c3p0.idle_test_period" value="60" />

		</properties>
	</persistence-unit>



</persistence>
